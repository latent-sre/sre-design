{
  "name": "sre-design",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "ruff.nativeServer": "on",
        "ruff.importStrategy": "fromEnvironment"
      }
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -e \".[dev]\"",
  "remoteUser": "vscode"
}
