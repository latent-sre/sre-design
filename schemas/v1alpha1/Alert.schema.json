{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/Alert.schema.json",
  "title": "Alert",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "Alert" },
    "spec": {
      "type": "object",
      "required": ["alertType", "signalSource", "expr"],
      "properties": {
        "alertType": { "type": "string", "enum": ["burn-rate", "threshold"] },
        "sloRef": { "type": ["string", "null"] },
        "signalSource": { "type": "string", "enum": ["log-pattern", "metric"] },
        "severity": { "type": "string" },
        "forFlow": { "type": "string" },
        "logFormatRef": { "type": ["string", "null"] },
        "expr": { "type": "object" },
        "rationale": { "type": "string" }
      }
    }
  }
}
