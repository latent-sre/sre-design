{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/ConfigManagement.schema.json",
  "title": "ConfigManagement",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "ConfigManagement" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" } },
        "profiles": { "type": "array" },
        "refreshScope": { "type": "boolean" },
        "properties": { "type": "array" }
      }
    }
  }
}
