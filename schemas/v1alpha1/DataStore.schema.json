{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/DataStore.schema.json",
  "title": "DataStore",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "DataStore" },
    "spec": {
      "type": "object",
      "required": ["engine", "name"],
      "properties": {
        "engine": { "type": "string" },
        "name": { "type": "string" },
        "accessedBy": { "type": "array" },
        "migrations": { "type": "array" },
        "backup": { "type": ["string", "null"] },
        "rpo": { "type": ["string", "null"] },
        "rto": { "type": ["string", "null"] },
        "sharedBy": { "type": "array" }
      }
    }
  }
}
