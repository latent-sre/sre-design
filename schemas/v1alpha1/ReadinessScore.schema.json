{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/ReadinessScore.schema.json",
  "title": "ReadinessScore",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "ReadinessScore" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prrChecks", "score"],
      "properties": {
        "prrChecks": { "type": "object" },
        "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "grade": { "type": "string" },
        "coverage": { "type": "object" },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
