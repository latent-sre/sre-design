{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/ResiliencyGap.schema.json",
  "title": "ResiliencyGap",
  "description": "A resiliency gap an LLM pointer-generator (Tier B) proposed and the engine re-grounded with the shared signature library (HYBRID-PLAN §7.9). Always needs-review: nothing the LLM proposes can auto-verify.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "ResiliencyGap" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "severity", "sourceTier", "rederivation"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["missing-timeout", "unguarded-critical-dependency", "swallowed-failure", "data-loss-path", "missing-idempotency", "undocumented-job", "unbounded-resource"]
        },
        "target": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["high", "medium", "low"] },
        "rationale": { "type": ["string", "null"] },
        "rederivation": { "type": "string", "enum": ["confirmed"] },
        "sourceTier": { "type": "string", "enum": ["llm"] },
        "checked": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths the engine searched for a refuting signature before asserting the absence (honest negative)."
        }
      }
    }
  }
}
