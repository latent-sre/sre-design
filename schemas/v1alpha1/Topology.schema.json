{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/Topology.schema.json",
  "title": "Topology",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "Topology" },
    "spec": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "name"],
            "properties": {
              "type": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relation": { "type": "string" }
            }
          }
        },
        "pcfSpaces": { "type": "array" }
      }
    }
  }
}
