{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/Alert.schema.json",
  "title": "Alert",
  "description": "An alerting rule grounded in the scan: SLO burn-rate (multi-window/multi-burn-rate on an ingested objective) or a log-pattern alert keyed on a parsed log statement. Rendered per backend by the alert adapters; `expr` carries the tool-neutral intent, never a hand-written query.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "Alert" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alertType", "signalSource", "expr"],
      "properties": {
        "alertType": { "type": "string", "enum": ["burn-rate", "threshold"] },
        "sloRef": { "type": ["string", "null"] },
        "signalSource": { "type": "string", "enum": ["log-pattern", "metric"] },
        "severity": { "type": "string" },
        "forFlow": { "type": "string" },
        "logFormatRef": { "type": ["string", "null"] },
        "expr": { "type": "object" },
        "rationale": { "type": "string" },

        "class": {
          "type": "string",
          "enum": ["symptom", "cause"],
          "description": "SRE alert class (adopted from resiliency-skills AlertIntent): symptom = user-visible SLO burn; cause = a specific failure mode (e.g. a swallowed publish)."
        },
        "signal": {
          "type": "object",
          "additionalProperties": false,
          "description": "Tool-neutral description of what is observed (the intent), independent of any backend's query dialect.",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["log", "metric", "trace", "synthetic"] },
            "metric": { "type": "string" },
            "route": { "type": ["string", "null"] },
            "description": { "type": "string" }
          }
        },
        "condition": {
          "type": "object",
          "additionalProperties": false,
          "description": "Tool-neutral threshold for a threshold-type alert.",
          "required": ["comparator", "threshold"],
          "properties": {
            "comparator": { "type": "string", "enum": [">", ">=", "<", "<=", "==", "!="] },
            "threshold": { "type": ["number", "string"] },
            "window": { "type": "string" },
            "occurrences": { "type": "integer", "minimum": 1 }
          }
        },
        "burnRate": {
          "type": "object",
          "additionalProperties": false,
          "description": "Structured multi-window error-budget burn-rate parameters (the intent behind the rendered `expr`).",
          "required": ["sloRef", "shortWindow", "longWindow"],
          "properties": {
            "sloRef": { "type": "string" },
            "sli": { "type": "string", "enum": ["latency", "availability"] },
            "shortWindow": { "type": "string" },
            "longWindow": { "type": "string" },
            "shortFactor": { "type": "number" },
            "longFactor": { "type": "number" },
            "budgetFraction": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "renderTargets": {
          "type": "array",
          "description": "Monitoring backends the `expr` was rendered for (adopted from AlertIntent.renderTargets).",
          "items": { "type": "string", "enum": ["prometheus", "splunk", "wavefront", "appdynamics", "grafana", "thousandeyes"] }
        }
      }
    }
  }
}
