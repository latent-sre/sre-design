{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/Architecture.schema.json",
  "title": "Architecture",
  "description": "The service's architecture narrative: components, layers, and design patterns/styles in use. Largely Tier-B (LLM judgment over the scanned structure), so it lands needs-review.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "Architecture" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components"],
      "properties": {
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "symbol": { "type": "string" }
            }
          }
        },
        "layers": { "type": "array", "items": { "type": "string" } },
        "patterns": { "type": "array", "items": { "type": "string" } },
        "styleTags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
