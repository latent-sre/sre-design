{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/BlastRadius.schema.json",
  "title": "BlastRadius",
  "description": "Engine-computed failure impact for one node (dependency/broker/datastore): the flows and services degraded when it fails, containment present or absent, co-tenancy across services, and whether state makes failure lossy. Labeled a best-effort lower bound \u2014 flow gaps may hide impact.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "BlastRadius" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "impactedFlows"],
      "properties": {
        "node": {
          "type": "object",
          "required": ["type", "name"],
          "properties": {
            "type": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "impactedFlows": { "type": "array", "items": { "type": "string" } },
        "impactedServices": { "type": "array", "items": { "type": "string" } },
        "indirectServices": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The subset of impactedServices reached transitively (bounded-depth walk of resolved calls edges against their direction), not by binding the node directly."
        },
        "containment": { "type": "array" },
        "coTenancy": { "type": "array" },
        "stateful": {
          "type": "object",
          "properties": { "dataLossRisk": { "type": "boolean" } }
        },
        "dependencyCriticality": { "type": "string" },
        "severityHint": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "riskRationale": { "type": "string" }
      }
    }
  }
}
