{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/Dependency.schema.json",
  "title": "Dependency",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "Dependency" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["datastore", "broker", "service-binding", "http", "library"] },
        "source": { "type": "string" },
        "baseUrl": { "type": ["string", "null"] },
        "engine": { "type": ["string", "null"], "description": "Datastore/broker engine (e.g. postgres, kafka) — folded in from the former DataStore kind (S1: app binds X, not the infra)." },
        "criticality": { "type": "string" }
      }
    }
  }
}
