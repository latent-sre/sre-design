{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/NetworkTopology.schema.json",
  "title": "NetworkTopology",
  "description": "Network ingress, egress, and trust-zone information.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "NetworkTopology" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": { "type": "array", "items": { "type": "string" } },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "protocol": { "type": "string" },
              "port": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "zones": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
