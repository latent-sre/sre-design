{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre.kb/schemas/v1alpha1/TechStack.schema.json",
  "title": "TechStack",
  "description": "The detected stack: languages, frameworks, runtime, build tool, operationally notable libraries, and the PCF buildpack context.",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "const": "TechStack" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frameworks"],
      "properties": {
        "languages": { "type": "array", "items": { "type": "string" } },
        "frameworks": { "type": "array" },
        "runtime": { "type": "string" },
        "buildTool": { "type": "string" },
        "notableLibraries": { "type": "array", "items": { "type": "string" } },
        "pcf": { "type": "object" }
      }
    }
  }
}
